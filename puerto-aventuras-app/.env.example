# Database
DATABASE_URL="postgresql://user:password@localhost:5432/puerto_aventuras?schema=public"

# JWT Secrets
JWT_ACCESS_SECRET="your-super-secret-access-key-min-32-chars"
JWT_REFRESH_SECRET="your-super-secret-refresh-key-min-32-chars"
JWT_ACCESS_EXPIRY="15m"
JWT_REFRESH_EXPIRY="7d"

# Encryption (AES-256)
ENCRYPTION_KEY="your-32-character-hex-encryption-key"

# API Configuration
API_PORT=3001
API_HOST=localhost
API_URL=http://localhost:3001

# Frontend Configuration
WEB_PORT=3000
WEB_URL=http://localhost:3000

# Email Service (for verification)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=noreply@puertoaventuras.com
SMTP_PASS=your-smtp-password

# MQTT (IoT)
MQTT_BROKER_URL=mqtt://localhost:1883
MQTT_USERNAME=
MQTT_PASSWORD=

# Redis (for sessions & caching)
REDIS_URL=redis://localhost:6379

# External Payment Processor
PAYMENT_PROCESSOR_API_KEY=
PAYMENT_PROCESSOR_SECRET=

# Environment
NODE_ENV=development
LOG_LEVEL=debug

# Rate Limiting
RATE_LIMIT_TTL=900
RATE_LIMIT_MAX=100

# CORS
CORS_ORIGIN=http://localhost:3000
